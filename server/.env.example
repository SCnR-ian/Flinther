# ── Server ──────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/ttclub

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# ── Session (used by Passport during OAuth flow) ─────────
SESSION_SECRET=change_this_to_another_long_random_string

# ── OAuth – Google ────────────────────────────────────────
# Create credentials at https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8000/api/auth/google/callback

# ── OAuth – Facebook ──────────────────────────────────────
# Create app at https://developers.facebook.com
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:8000/api/auth/facebook/callback

# ── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
